{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schema/master/tauri.schema.json",
  "productName": "Marianne AI",
  "version": "0.0.2",
  "identifier": "fr.marianne.app",
  "build": {
    "frontendDist": "../marianne-web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../marianne-web && npm run dev",
    "beforeBuildCommand": "cd ../marianne-web && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Marianne — Assistant Administratif",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://huggingface.co https://service-public.fr https://www.service-public.fr https://legifrance.gouv.fr https://www.legifrance.gouv.fr https://urssaf.fr https://www.urssaf.fr https://autoentrepreneur.urssaf.fr https://caf.fr https://www.caf.fr https://ameli.fr https://www.ameli.fr https://francetravail.fr https://www.francetravail.fr"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../corpus/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null
    }
  }
}
